<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fractal Animation</title>
    <style>
        body {
            margin: 0;
            overflow: hidden;
            background: #1a1a1a;
        }
    </style>
</head>
<body>
<canvas id="canvas"></canvas>

<script>
    const canvas = document.getElementById('canvas');
    const ctx = canvas.getContext('2d');
    let w, h;
    let iterations = 6;

    function resizeCanvas() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
    }
    window.onresize = resizeCanvas;
    resizeCanvas();

    function drawFractal(x, y, size, iteration) {
        if (iteration > 0) {
            const angle = Math.random() * Math.PI * 2;
            const newX = x + Math.cos(angle) * size;
            const newY = y + Math.sin(angle) * size;

            const newSize = size * 0.7;
            const newIteration = iteration - 1;
            
            // Draw a line
            ctx.beginPath();
            ctx.moveTo(x, y);
            ctx.lineTo(newX, newY);
            ctx.strokeStyle = `hsl(${Math.random() * 360}, 100%, 50%)`;
            ctx.lineWidth = Math.random() * 2 + 1;
            ctx.stroke();

            // Recurse for multiple fractal branches
            drawFractal(newX, newY, newSize, newIteration);
        }
    }

    function animate() {
        ctx.clearRect(0, 0, w, h);

        const centerX = w / 2;
        const centerY = h / 2;
        const maxSize = Math.min(w, h) / 5;

        // Randomize fractal colors and drawing angle every frame
        drawFractal(centerX, centerY, maxSize, iterations);

        requestAnimationFrame(animate);
    }

    animate();
</script>

</body>
</html>
