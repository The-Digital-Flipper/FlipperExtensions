{
  "manifest_version": 3,
  "name": "Flipper Extensions",
  "version": "1.0.0",
  "description": "Starter Chrome extension for the Flipper AI project.",
  "action": {
    "default_title": "Flipper Extensions",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
